# Copy this file to ".env" and fill in your own values.

# Required for the built-in AI chat/help assistant.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: which Claude model powers the chat assistant.
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Optional: YOLOv8 weights. Smaller = faster, larger = more accurate.
# Options (smallest to largest): yolov8n.pt, yolov8s.pt, yolov8m.pt, yolov8l.pt, yolov8x.pt
YOLO_MODEL=yolov8s.pt

# Optional: confidence thresholds (0.0 - 1.0). Higher = fewer but more
# confident detections.
YOLO_CONF_THRESHOLD=0.55
CLIP_CONF_THRESHOLD=0.35
